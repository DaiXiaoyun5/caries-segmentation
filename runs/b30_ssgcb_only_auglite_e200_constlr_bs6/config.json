{
  "run_name": "b30_ssgcb_only_auglite_e200_constlr_bs6",
  "image_size": 512,
  "augment_profile": "lite",
  "batch_size": 6,
  "epochs": 200,
  "lr": 0.0003,
  "weight_decay": 0.0001,
  "num_workers": 2,
  "seed": 42,
  "encoder_name": "resnet34",
  "encoder_weights": "imagenet",
  "ssgcb_branch_channels": 96,
  "ssgcb_dilations": [
    1,
    3,
    5
  ],
  "ssgcb_dropout": 0.0,
  "ssgcb_scale_init": 0.05,
  "ssgcb_scale_max": 0.3,
  "model_class": "ResNet34UNetB30SSGCBOnly",
  "experiment": "B30 ablation: plain ResNet34-U-Net + SSGCB only",
  "note": "This is the module-only ablation for B30-light. It inserts the same Selective Spatial-Gated Context Bottleneck on the deepest encoder feature of a plain ResNet34-U-Net, while removing boundary/rim auxiliary supervision and RBSG-lite. Training recipe is unchanged.",
  "ablation_of": "B30-light: B2 + SSGCB",
  "br_auxiliary_supervision": false,
  "rbsg": false,
  "ssgcb": {
    "enabled": true,
    "position": "deepest encoder bottleneck feature before decoder",
    "branch_channels": 96,
    "dilations": [
      1,
      3,
      5
    ],
    "global_branch": true,
    "dynamic_scale_selection": "softmax(MLP(GAP(sum(branches))))",
    "spatial_gate": "sigmoid(Conv7x7([mean(B), max(B)]))",
    "dropout": 0.0,
    "scale_init": 0.05,
    "scale_max": 0.3,
    "fusion": "F_out = F + bounded_scale * Conv1x1(B_g)"
  },
  "loss": {
    "main": "BCEWithLogits + Dice",
    "boundary": null,
    "rim": null,
    "total": "L_seg only"
  },
  "augmentation": {
    "type": "online",
    "profile": "lite",
    "train_only": true,
    "geometry": {
      "rotation_deg": [
        -15.0,
        15.0
      ],
      "scale": [
        0.85,
        1.2
      ],
      "translate_ratio": 0.05,
      "horizontal_flip_p": 0.5,
      "vertical_flip_p": 0.0
    },
    "photometric": {
      "brightness_factor": [
        0.85,
        1.15
      ],
      "contrast_factor": [
        0.85,
        1.15
      ],
      "gamma": [
        0.8,
        1.25
      ],
      "gaussian_noise_p": 0.1,
      "noise_std": [
        0.005,
        0.02
      ],
      "gaussian_blur_p": 0.1,
      "blur_radius": [
        0.2,
        0.8
      ]
    }
  }
